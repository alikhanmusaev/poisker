    <style name="Theme.Poisker" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/poisker_primary</item>
        <item name="android:navigationBarColor">@color/poisker_background</item>
        <item name="android:windowBackground">@color/poisker_background</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
