<?xml version="1.0" encoding="utf-8"?>
<!-- Site has no dark theme — keep light chrome to avoid forcing inverted WebView. -->
<resources>
    <style name="Theme.Poisker" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@color/poisker_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>
</resources>
