<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Poisker" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@color/poisker_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">true</item>
    </style>

    <style name="Theme.Poisker.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/poisker_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.Poisker</item>
    </style>
</resources>
