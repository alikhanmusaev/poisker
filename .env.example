FLASK_ENV=development
SECRET_KEY=dev-secret-key
DATABASE_URL=sqlite:///chechnya_board.db
# For Docker/production use:
# POSTGRES_USER=board
# POSTGRES_PASSWORD=replace-with-strong-postgres-password
# POSTGRES_DB=chechnya_board
# DATABASE_URL=postgresql+psycopg://board:replace-with-strong-postgres-password@postgres:5432/chechnya_board
RATELIMIT_STORAGE_URI=memory://
# Redis in Docker: redis://redis:6379/1
# RATELIMIT_ENABLED=false  — отключить лимиты локально
RATELIMIT_DEFAULT=600 per minute
REDIS_URL=redis://localhost:6379/0
TYPESENSE_URL=http://localhost:8108
TYPESENSE_API_KEY=replace-with-strong-typesense-key
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=replace-with-strong-s3-access-key
S3_SECRET_KEY=replace-with-strong-s3-secret-key
S3_BUCKET=board-images
S3_PUBLIC_URL=https://poisker.ru/media
CAPTCHA_PROVIDER=builtin
REQUIRE_CAPTCHA=false
CAPTCHA_TTL_SECONDS=600
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
SMARTCAPTCHA_SITE_KEY=
SMARTCAPTCHA_SECRET_KEY=
HMAC_SECRET=dev-hmac-secret
PHONE_ENCRYPTION_KEY=dev-phone-encryption-key
CONTACT_SOFT_LIMIT=5
CONTACT_RATE_LIMIT=30 per hour
MAX_IMAGE_PIXELS=20000000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=dev-admin-password
POST_EXPIRY_DAYS=30
DELETED_POST_RETENTION_DAYS=30
DELETED_POST_CLEANUP_BATCH_SIZE=100
PROMOTION_BOOST_24H_AMOUNT=100
SEED_DEMO_DATA=1
# Google Play / TWA / SEO
APP_DOMAIN=poisker.ru
SITE_NAME=Поискер
SITE_TAGLINE=Доска объявлений Чеченской Республики
# Optional: pin asset cache busting on deploy (auto from file hashes if unset)
# STATIC_VERSION=2026-07-02
ANDROID_PACKAGE_NAME=ru.poisker.app
ANDROID_SHA256_FINGERPRINTS=
SUPPORT_EMAIL=support@example.com
# Production behind HTTPS reverse proxy:
# SESSION_COOKIE_SECURE=true
# TRUST_PROXY=true
# REQUIRE_CAPTCHA=true
# HSTS_ENABLED=true
# RUN_DB_UPGRADE=false
# RUN_DB_INIT=false
# WEB_CONCURRENCY=2
