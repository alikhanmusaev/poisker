DJANGO_DEBUG=true
SECRET_KEY=dev-secret-key
HMAC_SECRET=dev-hmac-secret
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:8000,http://127.0.0.1:8000

# Postgres in Docker:
# POSTGRES_USER=board
# POSTGRES_PASSWORD=board
# POSTGRES_DB=chechnya_board
# DATABASE_URL=postgresql+psycopg://board:board@postgres:5432/chechnya_board
USE_SQLITE=1

REDIS_URL=redis://localhost:6379/0
TYPESENSE_URL=http://localhost:8108
TYPESENSE_API_KEY=typesenseKey
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=board-images
S3_PUBLIC_URL=http://localhost:9000/board-images

CONTACT_RATE_LIMIT_PER_HOUR=30
MAX_IMAGE_PIXELS=20000000
POST_EXPIRY_DAYS=30
DELETED_POST_RETENTION_DAYS=30
NOTIFY_SELLER_EMAIL=true
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

APP_DOMAIN=poisker.ru
SITE_NAME=Поискер
SITE_TAGLINE=Доска объявлений
SUPPORT_EMAIL=info@poisker.ru

# Firebase Cloud Messaging (server). Never commit the credentials JSON.
FIREBASE_PROJECT_ID=poisker-84437
FIREBASE_CREDENTIALS_FILE=
FCM_ENABLED=true
