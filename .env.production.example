DJANGO_DEBUG=false

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-random-secret-key
HMAC_SECRET=replace-with-random-hmac-secret
ALLOWED_HOSTS=poisker.ru,www.poisker.ru
CSRF_TRUSTED_ORIGINS=https://poisker.ru,https://www.poisker.ru

POSTGRES_USER=board
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=chechnya_board

REDIS_PASSWORD=replace-with-strong-redis-password
REDIS_URL=redis://:replace-with-strong-redis-password@redis:6379/0

TYPESENSE_URL=http://typesense:8108
TYPESENSE_API_KEY=replace-with-strong-typesense-key
TYPESENSE_ENABLE_CORS=false

S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=replace-with-strong-s3-access-key
S3_SECRET_KEY=replace-with-strong-s3-secret-key
S3_BUCKET=board-images
S3_PUBLIC_URL=https://poisker.ru/media

SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax
TRUST_PROXY=true
HSTS_ENABLED=true
SECURE_SSL_REDIRECT=true

SCHEDULER_ENABLED=true
WEB_CONCURRENCY=2

POST_EXPIRY_DAYS=30
DELETED_POST_RETENTION_DAYS=30
DELETED_POST_CLEANUP_BATCH_SIZE=100
CONTACT_RATE_LIMIT_PER_HOUR=30
NOTIFY_SELLER_EMAIL=true
DEFAULT_FROM_EMAIL=noreply@poisker.ru
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.mail.selcloud.ru
# EMAIL_PORT=1127
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_SSL=true
# EMAIL_USE_TLS=false

APP_DOMAIN=poisker.ru
SITE_NAME=Поискер
SITE_TAGLINE=Доска объявлений по Чеченской Республике
SUPPORT_EMAIL=support@poisker.ru

# Оператор ПДн (ИП)
OPERATOR_NAME=Индивидуальный предприниматель Мусаев Алихан Хизирович
OPERATOR_INN=201404274205
OPERATOR_OGRNIP=326200000008112
OPERATOR_ADDRESS=Чеченская Республика, с. Автуры, ул. Махмуда Махаджиева, д. 2
PDN_CONSENT_VERSION=2026-07-16b

# Ops: backups + monitoring (scripts/backup.sh, scripts/monitor.sh)
# Until DNS points to this host, keep MONITOR_USE_LOCAL=true (checks 127.0.0.1).
MONITOR_USE_LOCAL=true
MONITOR_URL=https://poisker.ru/health
MONITOR_TELEGRAM_BOT_TOKEN=
MONITOR_TELEGRAM_CHAT_ID=
MONITOR_ALERT_INTERVAL_SEC=1800
MONITOR_DISK_WARN_PCT=85
BACKUP_RETENTION_DAYS_DB=14
BACKUP_RETENTION_DAYS_MINIO=7
