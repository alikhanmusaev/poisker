FLASK_ENV=production

# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=replace-with-random-secret-key
HMAC_SECRET=replace-with-random-hmac-secret
PHONE_ENCRYPTION_KEY=replace-with-random-phone-encryption-key
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-admin-password

POSTGRES_USER=board
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=chechnya_board

RATELIMIT_STORAGE_URI=redis://redis:6379/1
REDIS_URL=redis://redis:6379/0

TYPESENSE_URL=http://typesense:8108
TYPESENSE_API_KEY=replace-with-strong-typesense-key

S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=replace-with-strong-s3-access-key
S3_SECRET_KEY=replace-with-strong-s3-secret-key
S3_BUCKET=board-images
S3_PUBLIC_URL=https://poisker.ru/media

# CAPTCHA: builtin (по умолчанию, без внешних сервисов), yandex, turnstile, none
CAPTCHA_PROVIDER=builtin
REQUIRE_CAPTCHA=true
CAPTCHA_TTL_SECONDS=600

SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=Lax
TRUST_PROXY=true
HSTS_ENABLED=true

SCHEDULER_ENABLED=true
RUN_DB_UPGRADE=true
RUN_DB_INIT=false
WEB_CONCURRENCY=2

POST_EXPIRY_DAYS=30
DELETED_POST_RETENTION_DAYS=30
DELETED_POST_CLEANUP_BATCH_SIZE=100
PROMOTION_BOOST_24H_AMOUNT=100
SEED_DEMO_DATA=0

APP_DOMAIN=poisker.ru
SITE_NAME=Поискер
SITE_TAGLINE=Доска объявлений Чеченской Республики
SUPPORT_EMAIL=support@example.com
ANDROID_PACKAGE_NAME=ru.poisker.app
ANDROID_SHA256_FINGERPRINTS=
